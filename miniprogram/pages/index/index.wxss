.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========== 主题变量 ========== */
.theme-dark {
  --bg: #14141f;
  --bg-canvas: #0e0e16;
  --card: #1e1e2e;
  --border: #2c2c3e;
  --text: #f0f0f5;
  --text-dim: rgba(240, 240, 245, 0.55);
  --accent: #7c6cff;
}

.theme-light {
  --bg: #f4f4f8;
  --bg-canvas: #ffffff;
  --card: #ffffff;
  --border: #e2e2ec;
  --text: #1c1c28;
  --text-dim: rgba(28, 28, 40, 0.5);
  --accent: #6a5ae0;
}

.page {
  background: var(--bg);
  color: var(--text);
}

/* ========== 主页与历史记录 ========== */
.home-scroll {
  flex: 1;
  min-height: 0;
}

.home {
  padding: 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.empty-card {
  width: 100%;
  background: var(--card);
  border: 2rpx dashed var(--border);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-dim);
  text-align: center;
  line-height: 1.7;
  margin-bottom: 48rpx;
  white-space: pre-line;
}

.btn-primary {
  background: var(--accent);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 96rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(124, 108, 255, 0.35);
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.empty-tip {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: var(--text-dim);
  text-align: center;
}

.history-section {
  margin-top: 48rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 32rpx;
  font-weight: 700;
}

.history-count {
  font-size: 22rpx;
  color: var(--text-dim);
}

.history-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.history-card {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  overflow: hidden;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 24rpx;
  box-sizing: border-box;
}

.history-card:active {
  transform: scale(0.97);
  border-color: var(--accent);
}

.history-thumb {
  display: block;
  width: 100%;
  height: 210rpx;
  background: var(--bg-canvas);
}

.history-body {
  display: flex;
  flex-direction: column;
  padding: 18rpx;
}

.history-name {
  overflow: hidden;
  color: var(--text);
  font-size: 25rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-meta {
  margin-top: 8rpx;
  color: var(--text-dim);
  font-size: 22rpx;
}

.history-time {
  margin-top: 6rpx;
  color: var(--text-dim);
  font-size: 20rpx;
  opacity: 0.75;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 44rpx;
  padding: 40rpx 24rpx;
  border: 2rpx dashed var(--border);
  border-radius: 24rpx;
}

.history-empty-title {
  color: var(--text);
  font-size: 26rpx;
  font-weight: 600;
}

.history-empty-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 22rpx;
  text-align: center;
  line-height: 1.6;
}

/* ========== 画布（流式，占满中间区域） ========== */
.board {
  flex: 1;
  width: 100%;
  min-height: 0;
}

.back-swipe-zone {
  position: fixed;
  z-index: 50;
  top: 0;
  bottom: 0;
  left: 0;
  width: 64rpx;
}

/* ========== 顶部栏 ========== */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--bg);
  flex-shrink: 0;
}

.topbar-btn {
  background: var(--card);
  border: 2rpx solid var(--border);
  color: var(--text);
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  opacity: 0.92;
}

.topbar-btn:active {
  transform: scale(0.94);
}

.topbar-info {
  background: var(--card);
  border: 2rpx solid var(--border);
  color: var(--text-dim);
  font-size: 22rpx;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  opacity: 0.92;
}

/* ========== 底部颜色面板 ========== */
.panel {
  background: var(--card);
  border-top: 2rpx solid var(--border);
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 16rpx;
}

.panel-title {
  font-size: 24rpx;
  color: var(--text-dim);
}

.panel-clear {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
}

.chips {
  white-space: nowrap;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 0 8rpx;
  padding: 12rpx 8rpx;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: transform 0.15s ease;
}

.chip:active {
  transform: scale(0.92);
}

.chip-active {
  border-color: var(--accent);
  background: rgba(124, 108, 255, 0.12);
}

.chip-color {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  box-sizing: border-box;
}

.chip-code {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text);
  margin-top: 8rpx;
}

.chip-count {
  font-size: 20rpx;
  color: var(--text-dim);
  margin-top: 2rpx;
}

/* ========== 豆盘档位选择 ========== */
.size-row {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 0;
}

.size-label {
  font-size: 22rpx;
  color: var(--text-dim);
  flex-shrink: 0;
  margin-right: 12rpx;
}

.sizes {
  flex: 1;
  white-space: nowrap;
}

.size-chip {
  display: inline-block;
  font-size: 22rpx;
  color: var(--text-dim);
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
  margin: 0 6rpx;
}

.size-chip:active {
  transform: scale(0.94);
}

.size-active {
  color: #ffffff;
  background: var(--accent);
  border-color: var(--accent);
}

/* ========== 校准面板 ========== */
.adjust-row {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 32rpx 24rpx;
}

.stepper {
  display: flex;
  align-items: center;
}

.stepper-label {
  font-size: 26rpx;
  color: var(--text-dim);
  margin-right: 16rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg);
  border: 2rpx solid var(--border);
  color: var(--text);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stepper-btn:active {
  transform: scale(0.9);
  border-color: var(--accent);
}

.stepper-val {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.adjust-confirm {
  margin: 0 32rpx;
  text-align: center;
  padding: 20rpx 0;
}
